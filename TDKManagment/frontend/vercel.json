{
  "buildCommand": "cd TDKManagment/frontend && npm install && npm run build",
  "outputDirectory": "TDKManagment/frontend/dist",
  "installCommand": "cd TDKManagment && npm install",
  "functions": {
    "TDKManagment/api/*.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}