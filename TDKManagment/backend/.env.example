# Copia este archivo a .env y completa con tus datos de PostgreSQL
# cp .env.example .env

PORT=3001

# PostgreSQL (ajusta según tu instalación)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=tu_password
PGDATABASE=tdk_management

# Opcional: usar una sola URL en lugar de variables sueltas
# DATABASE_URL=postgresql://usuario:password@localhost:5432/tdk_management
